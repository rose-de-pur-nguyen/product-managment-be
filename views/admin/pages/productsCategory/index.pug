extends ../../layouts/default.pug 

block main 
    

    h1 Danh mục sản phẩm

    //- _id
    //- title 
    //- parent_id 
    //- description
    //- thumbnail 
    //- status 
    //- position 
    //- deleted 
    //- deletedAt 
    //- createdAt 
    //- updatedAt 
    //- slug

    .card.mb-3 
        .card-header Danh sách 
        .card-body
            .row
                .col-8
                .col-4 
                    a(
                        href=`${prefixAdmin}/products-category/create`
                        class='btn btn-outline-success'
                    ) + Thêm mới
    
        table(
            class="table table-hover table-sm"
            checkbox-multi
        )
            thead 
                tr 
                    th
                        input(type="checkbox" name="checkall")
                    th STT 
                    th Hình ảnh 
                    th Tiêu đề
                    th Vị trí
                    th Trạng thái 
                    th Hành động
            
            tbody 
                each item, index in records
                    tr 
                        td 
                            input(
                                type="checkbox"
                                name="id"
                                value=item.id
                            )
                        td #{index + 1}
                        td 
                            img(
                                src=item.thumbnail
                                alt=`sản phẩm ${index + 1}` 
                                width="100px"
                                height="auto"
                            )
                        td #{item.title}
                        td 
                            input(
                                type="number"
                                value=item.position 
                                style="width: 60px"
                                min="1"
                                name="position"
                            )
                        td 
                            if(item.status == "active")
                                //- href=`/admin/products/change-status/inactive/${item.id}`
                                //- dont use the above link cause the default method is GET while we have to use PATCH

                                //- javascript:;  => telling nodejs that we use javascript to handle the logic
                                a.badge.bg-success(
                                    href="javascript:;"
                                    data-status="active"
                                    data-id=item.id
                                    button-change-status
                                ) Hoạt động
                            else 
                                a.badge.bg-danger(
                                    href="javascript:;"
                                    data-status="inactive"
                                    data-id=item.id
                                    button-change-status
                                ) Dừng hoạt động
                        td  
                            a(
                                href=`${prefixAdmin}/products-category/detail/${item.id}`
                                class="btn btn-secondary btn-sm"
                            ) Chi tiết
                            a(
                                href=`${prefixAdmin}/products-category/edit/${item.id}`
                                class="btn btn-warning btn-sm"
                            ) Sửa
                            button(
                                class="btn btn-danger btn-sm ms-1"
                                button-delete
                                data-id=item.id
                            ) Xóa 



    script(src="/admin/js/product.js")