extends ../../layouts/default.pug 

block main 
    h1(class="mb-4") Danh sách tài khoản 

    .card.mb-3 
        .card-header Danh sách 
        .card-body 
            .row 
                .col-8 
                .col-4 
                    a(
                        href=`${prefixAdmin}/accounts/create`
                        class="btn btn-outline-success"
                    ) + Thêm mới
    
            table(
                class="table table-hover table-sm mt-4"
            )
                thead 
                    tr 
                        th STT 
                        th Avatar
                        th Họ tên
                        th Phân quyền
                        th Email
                        th Trạng thái 
                        th Hành động
                
                tbody 
                    each item, index in records
                        tr 
                            td #{index+1}
                            //- td #{pagination.limitItems*(pagination.currentPage - 1) + (index + 1)}
                            td 
                                img(
                                    src=item.avatar
                                    alt=`sản phẩm ${index + 1}` 
                                    width="100px"
                                    height="auto"
                                )
                            td #{item.fullName}
                            td #{item.role.title}
                            td #{item.email}
                            td 
                                if(item.status == "active")
                                    //- href=`/admin/products/change-status/inactive/${item.id}`
                                    //- dont use the above link cause the default method is GET while we have to use PATCH

                                    //- javascript:;  => telling nodejs that we use javascript to handle the logic
                                    a.badge.bg-success(
                                        href="javascript:;"
                                        data-status="active"
                                        data-id=item.id
                                        button-change-status
                                    ) Hoạt động
                                else 
                                    a.badge.bg-danger(
                                        href="javascript:;"
                                        data-status="inactive"
                                        data-id=item.id
                                        button-change-status
                                    ) Dừng hoạt động
                            td  
                                a(
                                    href=`${prefixAdmin}/accounts/${item.id}`
                                    class="btn btn-secondary btn-sm"
                                ) Chi tiết
                                a(
                                    href=`${prefixAdmin}/accounts/edit/${item.id}`
                                    class="btn btn-warning btn-sm ms-1"
                                ) Sửa
                                button(
                                    class="btn btn-danger btn-sm ms-1"
                                    button-delete
                                    data-id=item.id
                                ) Xóa 
    
    //- +pagination(pagination)

    script(src="/admin/js/account.js")