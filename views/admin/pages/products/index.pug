extends ../../layouts/default.pug 
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort.pug

block main 
    +alert-success("5000")


    h1 Danh sách sản phẩm

    .card.mb-4
        .card-header Bộ lọc và tìm kiếm 
        .card-body 
            .row 
                .col-6
                    +filter-status(filterStatus)
                .col-6 
                    +search(keyword)
    
    .card.mb-3 
        .card-header Sắp xếp 
        .card-body 
            .row 
                .col-4 
                    +sort()

    .card.mb-3 
        .card-header Danh sách 
        .card-body
            .row
                .col-8
                    +form-change-multi(`${prefixAdmin}/products/change-multi?_method=PATCH`, page)
                .col-4 
                    a(
                        href=`${prefixAdmin}/products/create`
                        class='btn btn-outline-success'
                    ) + Thêm mới



            table(
                class="table table-hover table-sm mt-4"
                checkbox-multi
            )
                thead 
                    tr 
                        th
                            input(type="checkbox" name="checkall")
                        th STT 
                        th Hình ảnh 
                        th Tiêu đề
                        th Giá
                        th Vị trí
                        th Trạng thái 
                        th Hành động
                
                tbody 
                    each item, index in products
                        tr 
                            td 
                                input(
                                    type="checkbox"
                                    name="id"
                                    value=item.id
                                )
                            td #{index + 1}
                            td 
                                img(
                                    src=item.thumbnail
                                    alt=`sản phẩm ${index + 1}` 
                                    width="100px"
                                    height="auto"
                                )
                            td #{item.title}
                            td #{item.price}$
                            td 
                                input(
                                    type="number"
                                    value=item.position 
                                    style="width: 60px"
                                    min="1"
                                    name="position"
                                )
                            td 
                                if(item.status == "active")
                                    //- href=`/admin/products/change-status/inactive/${item.id}`
                                    //- dont use the above link cause the default method is GET while we have to use PATCH

                                    //- javascript:;  => telling nodejs that we use javascript to handle the logic
                                    a.badge.bg-success(
                                        href="javascript:;"
                                        data-status="active"
                                        data-id=item.id
                                        button-change-status
                                    ) Hoạt động
                                else 
                                    a.badge.bg-danger(
                                        href="javascript:;"
                                        data-status="inactive"
                                        data-id=item.id
                                        button-change-status
                                    ) Dừng hoạt động
                            td  
                                a(
                                    href=`${prefixAdmin}/products/detail/${item.id}`
                                    class="btn btn-secondary btn-sm"
                                ) Chi tiết
                                a(
                                    href=`${prefixAdmin}/products/edit/${item.id}`
                                    class="btn btn-warning btn-sm"
                                ) Sửa
                                button(
                                    class="btn btn-danger btn-sm ms-1"
                                    button-delete
                                    data-id=item.id
                                ) Xóa 
    
    +pagination(pagination)

    //- If we have the method-override (e.g to be PATCH)
    //- then the method of the form ALWAYS HAS TO BE "POST"
    form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/products/change-status`
    )
        input(
            type="hidden" 
            name="page" 
            value=page
        )
        //- dont declare this as one of the form's attributes cause form doesnt have 
        //- the "page" attribute
    
    form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/products/delete`
    )
        input(
            type="hidden"
            name="page"
            value=page
        )


    script(src="/admin/js/product.js")