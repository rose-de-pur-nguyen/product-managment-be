extends ../../layouts/default.pug 
include ../../mixins/alert.pug 

block main 
    +alert-error(5000)

    .container.my-5 
        .row.justify-content-center 
            .col-8  
                h1(class="text-center") Đăng nhập
                form(
                    action="/user/login"
                    method="POST"
                )  
                    div(class="form-group mb-3")
                        label(for="email") Email
                        input(
                            type="text"
                            class="form-control"
                            id="email"
                            name="email"
                        ) 
                    div(class="form-group mb-3")
                        label(for="password") Mật khẩu
                        input(
                            type="password"
                            class="form-control"
                            id="password"
                            name="password"
                        ) 
                    div(class="form-group mb-3")
                        button(
                            type="submit"
                            class="btn btn-primary btn-block"
                        ) Đăng nhập
            
                a(href="/user/password/forgot" style="text-decoration: none") Quên mật khẩu?